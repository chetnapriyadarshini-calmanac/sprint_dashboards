# ─────────────────────────────────────────────────────────────
# Secrets — NEVER commit these. Each lives as a single-line file
# at the repo root and is read by jira_auth.py.
# ─────────────────────────────────────────────────────────────
.jira_pat
.jira_email
.jira_site
.tfs_pat
.env
*.pat
*.token

# Google service-account keys (secret — used for the capacity Sheet)
.gcp_sa.json
service_account.json
*-sa.json
gcp-*.json
*serviceaccount*.json

# ─────────────────────────────────────────────────────────────
# Spreadsheets. The capacity workbook (Team_Capacity.xlsx) IS committed —
# it holds no sensitive data. Everything else .xlsx (stray exports, Excel
# lock/temp files) stays out.
# ─────────────────────────────────────────────────────────────
*.xlsx
!daily-dashboard/Team_Capacity.xlsx
~$*.xlsx
.~lock.*#

# ─────────────────────────────────────────────────────────────
# Generated data — regenerated by the scripts (structure kept via .gitkeep).
# ─────────────────────────────────────────────────────────────
# Snapshots (daily release + sprint waves)
snapshots/**/*.json
snapshots/**/*.csv

# Generated reports (retros, monthly retro)
reports/*
!reports/.gitkeep

# Run logs
logs/*
!logs/.gitkeep

# Daily dashboard outputs + per-sprint tracking history
daily-dashboard/*.html
daily-dashboard/Sprint*_history.json
daily-dashboard/*_mismatches.csv
*.json.bak
*.json.tmp

# ─────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.mypy_cache/
.pytest_cache/

# ─────────────────────────────────────────────────────────────
# OS / editor
# ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Keep empty data folders present in git
!**/.gitkeep
